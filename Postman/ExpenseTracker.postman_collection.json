                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": \"PASTE_EXTERNAL_ID_HERE\",\n  \"amount\": 4600,\n  \"merchant\": \"OPTP-LPC-GPL-UBIT\"\n}"
