{
  "info": {
    "name": "Expense Tracker Microservices APIs",
    "_postman_id": "d4d7f2b0-4f41-4d88-9b4d-123456789abc",
    "description": "Expense Tracker Project APIs routed through Kong Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"hassan\",\n  \"password\": \"123456\",\n  \"first_name\": \"Hassan\",\n  \"last_name\": \"Sherwani\",\n  \"phone_number\": 923001112233,\n  \"email\": \"hassan@gmail.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/auth/v1/register"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', response.access_token);",
                  "pm.collectionVariables.set('refreshToken', response.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"hassan\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/auth/v1/login"
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/auth/v1/validate"
            }
          }
        }
      ]
    },
    {
      "name": "User Service",
      "item": [
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/user/v1/getUser"
            }
          }
        }
      ]
    },
    {
      "name": "Expense Service",
      "item": [
        {
