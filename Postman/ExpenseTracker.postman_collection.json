              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 9900,\n  \"merchant\": \"KGFC\",\n  \"currency\": \"PKR\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/expense/v1/addExpense"
